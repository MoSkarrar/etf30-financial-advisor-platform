# =========================================================
# Project-specific: generated results and model artifacts
# =========================================================
# Ignore generated outputs by default
trader/drl_stock_trader/results/**
trader/drl_stock_trader/trained_models/**

# Keep folder structure in Git with .gitkeep files
!trader/drl_stock_trader/results/
!trader/drl_stock_trader/results/**/.gitkeep
!trader/drl_stock_trader/trained_models/
!trader/drl_stock_trader/trained_models/**/.gitkeep

